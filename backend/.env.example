# Application Settings
PROJECT_NAME="AI ProductOS"
ENVIRONMENT=development
API_V1_STR=/api/v1

# CORS settings (JSON list of origins)
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# PostgreSQL Configuration
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pwd_change_me
POSTGRES_DB=ai_product_os

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Security Config
JWT_SECRET=generate_a_secure_random_hex_string_with_32_bytes_or_more
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days
